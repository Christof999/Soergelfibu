// ═══════════════════════════════════════════════════════════════════════════
// Firebase Storage – Berechtigungen (Security Rules)
// ═══════════════════════════════════════════════════════════════════════════
//
// WAS STEHT HIER?
// Nur eingeloggte Nutzer (Google-Anmeldung in der App) dürfen Dateien in
// IHREM eigenen Ordner lesen und hochladen. Fremde Konten haben keinen Zugriff.
//
// ORDNER:
//   • projects/{Nutzer-ID}/...  → Projekt-Anhänge (wie bisher)
//   • fibu/{Nutzer-ID}/...       → PDF-Rechnungen in der Fibu
//
// AKTIVIEREN (einmal nach Änderung oder wenn die App „Storage verweigert“ meldet):
//   Im Projektordner im Terminal:
//     npx firebase-tools@latest deploy --only storage
//
// Voraussetzung: Firebase CLI ist mit dem Projekt „soergelfibu“ verbunden
// (firebase login, firebase use soergelfibu).
// ═══════════════════════════════════════════════════════════════════════════

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /projects/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /fibu/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
